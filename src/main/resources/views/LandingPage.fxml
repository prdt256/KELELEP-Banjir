<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="720.0" prefWidth="1280.0" styleClass="bg-dark" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kelelep.controller.LandingController">

    <VBox alignment="CENTER" spacing="30.0">
        <Label styleClass="title-hero" text="Selamat Datang" />

        <HBox alignment="CENTER" spacing="20.0">
            <Button onAction="#onUploadCsv" prefHeight="45.0" prefWidth="180.0" styleClass="btn-success" text="Upload File (.csv)" />
            <Button onAction="#onGoToDashboard" prefHeight="45.0" prefWidth="180.0" styleClass="btn-blue" text="Dashboard" />
        </HBox>
        <VBox alignment="CENTER" spacing="5.0">
            <Hyperlink onAction="#onShowCsvGuide" style="-fx-text-fill: #94A3B8; -fx-underline: true; -fx-font-size: 13px;" text="❓ Petunjuk Format CSV" />
            <Hyperlink onAction="#onOpenSpreadsheetTemplate" style="-fx-text-fill: #3B82F6; -fx-underline: true; -fx-font-size: 13px;" text="🔗 Buka Template Google Sheets (Eksternal)" />
        </VBox>
    </VBox>

    <Label styleClass="label-version-light" text="KELELEP v1.0" StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets bottom="20.0" right="30.0" />
        </StackPane.margin>
    </Label>
</StackPane>
